# Backend configuration — used by both local dev and production Docker Compose
# Copy to .env and fill in real values before running.

# Core scraper
SCRAPER_TIMEOUT=30
SCRAPER_FOLLOW_REDIRECTS=true
SCRAPER_ALLOW_PRIVATE_NETWORKS=false
SCRAPER_MAX_REDIRECTS=5
SCRAPER_MAX_LINKS=100
SCRAPER_MAX_IMAGES=50
SCRAPER_MAX_RAW_TEXT_CHARS=50000

# API
API_HOST=127.0.0.1
API_PORT=8000
APP_ENV=production
LOG_LEVEL=INFO
API_ALLOWED_ORIGINS=http://localhost:3000
API_TRUSTED_HOSTS=localhost,127.0.0.1,backend,nginx
API_KEYS=change-me
API_RATE_LIMIT_PER_MINUTE=60
API_SCRAPE_RATE_LIMIT_PER_MINUTE=60
API_RESEARCH_RATE_LIMIT_PER_MINUTE=15
API_MAX_CONCURRENT_REQUESTS=10
API_MAX_REQUEST_BYTES=65536
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
# PROMETHEUS_ALERT_WEBHOOK_TOKEN: reserved for future Alertmanager webhook integration — not consumed by any service yet
PROMETHEUS_API_KEY=change-me  # Must match one of the values in API_KEYS

# LLM backend
OLLAMA_HOST=http://localhost:11434
DEFAULT_RESEARCH_MODEL=gpt-oss:120b-cloud

# Research runtime knobs
RESEARCH_ENABLE_QUERY_REWRITE=true
RESEARCH_QUERY_REWRITE_MAX_VARIANTS=4
RESEARCH_QUERY_REWRITE_TIMEOUT_SECONDS=20.0
RESEARCH_ENABLE_GOOGLE_FALLBACK=true
RESEARCH_GOOGLE_FALLBACK_MIN_RESULTS=5
RESEARCH_RERANK_DOMAIN_DIVERSITY_BOOST=0.25
RESEARCH_RERANK_SAME_DOMAIN_PENALTY=0.08
RESEARCH_RERANK_EXACT_QUERY_BOOST=0.15
RESEARCH_MAX_CONCURRENT_SOURCES=5
RESEARCH_TIMEOUT_PER_SOURCE=30.0
RESEARCH_NORMAL_AUTO_MIN_SOURCES=1
RESEARCH_NORMAL_AUTO_MAX_SOURCES=15
RESEARCH_DEEP_MIN_SOURCES=15
RESEARCH_DEEP_MAX_SOURCES=50
RESEARCH_DEFAULT_NORMAL_SOURCE_TARGET=5
RESEARCH_DEFAULT_DEEP_SOURCE_TARGET=20
RESEARCH_SEARCH_POOL_EXTRA_NORMAL=5
RESEARCH_SEARCH_POOL_EXTRA_DEEP=10
RESEARCH_NORMAL_CONTENT_LIMIT_CHARS=2500
RESEARCH_DEEP_CONTENT_LIMIT_CHARS=8000
RESEARCH_NON_DEEP_SOURCE_CHAR_CAP=10000
RESEARCH_PLANNING_TIMEOUT_SECONDS=30.0
RESEARCH_SOURCE_SELECTION_TIMEOUT_SECONDS=60.0
RESEARCH_SYNTHESIS_TIMEOUT_SECONDS=120.0
RESEARCH_DEEP_SYNTHESIS_TIMEOUT_SECONDS=240.0
DUCKDUCKGO_REQUEST_TIMEOUT_SECONDS=30.0
DUCKDUCKGO_REQUEST_DELAY_SECONDS=0.5
GOOGLE_REQUEST_TIMEOUT_SECONDS=30.0

# General safety limits
MAX_QUERY_LENGTH=500
MAX_SOURCE_CONTENT_CHARS=12000
CACHE_TTL_SECONDS=300
CACHE_MAX_ENTRIES=256
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_SECONDS=30
HISTORY_DB_PATH=web_scraper_history.sqlite3
METRICS_ENABLED=true

# Nginx
NGINX_SERVER_NAME=localhost  # Set to your domain in production
