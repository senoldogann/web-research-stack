global:
  scrape_interval: 15s
  evaluation_interval: 15s

rule_files:
  - /etc/prometheus/alerts.yml

scrape_configs:
  - job_name: web_research_backend
    metrics_path: /api/v1/metrics
    scheme: http
    static_configs:
      - targets: ["backend:8000"]
    authorization:
      type: Bearer
      credentials: __API_KEY__

